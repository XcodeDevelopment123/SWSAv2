@{
    ViewData["Title"] = "BP33 - Form E Work Progress Schedule";
}

<h1>F3.2 Form E Work In Progress</h1>

<div class="row">
    <div class="col-md-12">
        <div id="alertContainer"></div>
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-tasks me-2"></i> F3.2 Records
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#taskModal" id="addNewBtn">
                        <i class="fas fa-plus me-2"></i>New Record
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="taskDatatable" class="table table-bordered table-striped text-nowrap">
                        <thead>
                            <tr>
                                <th colspan="3" class="text-center">Basic Info</th>
                                <th colspan="5" class="text-center">Tax Process & E-Filing</th>
                                <th colspan="1" class="text-center">Tax</th>
                                <th colspan="4" class="text-center">Login & Reference</th>
                                <th colspan="2" class="text-center">Billing & Dispatch</th>
                                <th rowspan="2" style="vertical-align: middle;">Actions</th>
                            </tr>

                            <tr>
                                <th>Item</th>
                                <th>Grouping</th>
                                <th>Company Name</th>

                                <th>Draft Form E</th>
                                <th>Review Form E</th>
                                <th>Form E Sign By Client</th>
                                <th>E-File Draft</th>
                                <th>E-File Final</th>

                                <th>Amount of Tax Pay</th>

                                <th>Reference No</th>
                                <th>Login</th>
                                <th>Password</th>
                                <th>Type of Form</th>

                                <th>Invoices No</th>
                                <th>Invoice Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="taskModal" tabindex="-1" aria-labelledby="taskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="taskModalLabel">
                    <i class="fas fa-edit me-2"></i>
                    <span id="modalTitle">Add New Form E Work In Progress</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="taskForm">
                    <input type="hidden" id="recordId" value="">

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="item">Item</label>
                                <input type="text" id="item" name="item" class="form-control" placeholder="Enter item" />
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="companyName">Company Name</label>
                                <select id="clientSelect" class="form-control">
                                    <option value="">-- Loading Clients... --</option>
                                </select>
                                <small class="text-muted fst-italic">Includes Sdn Bhd, LLP, Enterprise (Excludes Individual)</small>
                                <input type="hidden" id="companyName" name="companyName" />
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="grouping">Grouping</label>
                                <input type="text" id="grouping" name="grouping" class="form-control" placeholder="Auto-fill" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="draftFormE">Draft Form E</label>
                                @*  <input type="text" id="draftTaxCompleted" name="draftTaxCompleted" class="form-control datepicker" placeholder="Select date" /> *@
                                <select id="draftFormE" class="form-control">
                                    <option value="">Select Y/N</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="reviewTax">Review Form E</label>
                                @*   <input type="text" id="reviewTax" name="reviewTax" class="form-control datepicker" placeholder="Select date" /> *@
                                <select id="reviewTax" class="form-control">
                                    <option value="">Select Y/N</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        @*  <div class="col-md-6">
                            <div class="form-group">
                                <label for="finalTax">Final Tax</label>
                                <input type="text" id="finalTax" name="finalTax" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div> *@
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="formESignByClient">form E Sign By Client</label>
                                @* <input type="text" id="taxComFinalSignByClient" name="taxComFinalSignByClient" class="form-control datepicker" placeholder="Select date" /> *@
                                <select id="formESignByClient" class="form-control">
                                    <option value="">Select Y/N</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="taxReferennceNo">Tax<br /> Reference No</label>
                                <input type="text" id="taxReferennceNo" name="taxReferennceNo" class="form-control" placeholder="Enter reference number" />
                            </div>
                        </div>
                    </div>

                    @* <div class="row">
                <div class="col-md-6">
                     <div class="form-group">
                                <label for="amountofTaxPay">Amount of Tax Pay</label>
                                <input type="number" step="0.01" id="amountofTaxPay" name="amountofTaxPay" class="form-control" placeholder="0.00" />
                            </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="taxReferennceNo">Tax Reference No</label>
                        <input type="text" id="taxReferennceNo" name="taxReferennceNo" class="form-control" placeholder="Enter reference number" />
                    </div>
                </div>
            </div> *@

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="eFileDraft">E-File Draft</label>
                                @*   <input type="text" id="eFileDraft" name="eFileDraft" class="form-control datepicker" placeholder="Select date" /> *@
                                <select id="eFileDraft" class="form-control">
                                    <option value="">Select Y/N</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="eFileFinal">
                                    E-File Final Submitted

                                </label>
                                <input type="text" id="eFileFinal" name="eFileFinal" class="form-control datepicker" placeholder="Enter date" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="login">Login</label>
                                <input type="text" id="login" name="login" class="form-control" placeholder="Enter login" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="password">Password</label>
                                <input type="text" id="password" name="password" class="form-control" placeholder="Enter password" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="typeofForm">Type of Form E</label>
                                @* <input type="text" id="typeofForm" name="typeofForm" class="form-control" placeholder="Enter type of form" /> *@
                                <select id="draftFormE" class="form-control">
                                    <option value="">Select Type</option>
                                    <option value="Dormant">Dormant</option>
                                    <option value="Active">Active</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="invoicesNo">Invoices Date</label>
                                <input type="text" id="invoicesNo" name="invoicesNo" class="form-control" placeholder="Enter invoices number" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="invoiceAmount">Invoice Amount</label>
                                <input type="number" step="0.01" id="invoiceAmount" name="invoiceAmount" class="form-control" placeholder="0.00" />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-2"></i>Cancel</button>
                <button type="button" class="btn btn-primary" id="saveBtn"><i class="fas fa-save me-2"></i>Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>

    <script>
        $(document).ready(function() {
            let dataTable;
            let currentEditId = null;
            let clientOptionsMap = {}; // 存储 Client 数据

            // 🟢 1. 加载 Client List (过滤掉 Individual)
            function loadClientOptions() {
                $.ajax({
                    url: '/api/auditdept/clients/get-list', // 通用 API
                    type: 'GET',
                    success: function (res) {
                        if (res.success && res.data) {
                            clientOptionsMap = {};
                            const $sel = $('#clientSelect');
                            $sel.empty().append('<option value="">-- Select Company --</option>');

                            // 🟢 过滤掉 Individual
                            const filteredList = res.data.filter(c => c.clientType !== 'Individual');

                            filteredList.forEach(client => {
                                clientOptionsMap[client.id] = client;

                                // 显示格式：Name (Type)
                                let displayText = client.companyName;
                                if (client.clientType) {
                                    displayText += ` (${client.clientType})`;
                                }
                                $sel.append(`<option value="${client.id}">${displayText}</option>`);
                            });
                        }
                    },
                    error: function(xhr) {
                        console.error("Failed to load clients", xhr);
                    }
                });
            }

            // 🟢 2. Dropdown Change Event (Auto-fill Grouping)
            $('#clientSelect').change(function() {
                const selectedId = $(this).val();

                if (!selectedId || !clientOptionsMap[selectedId]) {
                    $('#companyName').val('');
                    $('#grouping').val('');
                    // 也可以选择清空其他关联字段
                    return;
                }

                const c = clientOptionsMap[selectedId];

                // 填入 Hidden Input
                $('#companyName').val(c.companyName || '');

                // 🟢 自动填入 Grouping
                $('#grouping').val(c.grouping || '');

                // 如果需要，也可以自动填入 File No 或 Reference No
                // if(c.fileNo) ...
            });

            // 初始化 DatePicker
            function initializeDatePickers() {
                $('.datepicker').datepicker({
                    format: 'yyyy-mm-dd',
                    autoclose: true,
                    todayHighlight: true
                });
            }

            function formatDate(dateString) {
                if (!dateString) return '';
                try {
                    const date = new Date(dateString);
                    return date.toLocaleDateString('en-GB');
                } catch (e) { return dateString; }
            }

            function formatDateForInput(dateString) {
                if (!dateString) return '';
                try {
                    const date = new Date(dateString);
                    return date.toISOString().split('T')[0];
                } catch (e) { return dateString; }
            }

            function showAlert(msg, type) {
                const html = `<div class="alert alert-${type} alert-dismissible fade show">${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
                $('#alertContainer').html(html);
                setTimeout(() => $('.alert').alert('close'), 3000);
            }

            function resetForm() {
                $('#taskForm')[0].reset();
                currentEditId = null;
                $('#recordId').val('');
                $('#clientSelect').val('');
                $('#modalTitle').text('Add New Form E WIP');
                $('.datepicker').datepicker('update', '');
            }

            // 初始化 DataTable
            function initializeDataTable() {
                if ($.fn.DataTable.isDataTable('#taskDatatable')) {
                    dataTable.destroy();
                }

                dataTable = $('#taskDatatable').DataTable({
                    "processing": true,
                    "serverSide": false,
                    "scrollX": true,
                    "ajax": {
                        "url": "/api/bp33/get-all",
                        "type": "GET",
                        "dataSrc": function(response) {
                            return response.success ? response.data : [];
                        },
                        "error": function(xhr, error, thrown) {
                            console.error('DataTable Error:', error);
                        }
                    },
                    "columns": [
                        { "data": "item", "defaultContent": "" },
                        { "data": "grouping", "defaultContent": "" },
                        { "data": "companyName", "defaultContent": "" },
                        {
                            "data": "draftTaxCompleted",
                            "render": function(data) { return data ? formatDate(data) : ''; },
                            "defaultContent": ""
                        },
                        {
                            "data": "reviewTax",
                            "render": function(data) { return data ? formatDate(data) : ''; },
                            "defaultContent": ""
                        },

                        {
                            "data": "taxComFinalSignByClient",
                            "render": function(data) { return data ? formatDate(data) : ''; },
                            "defaultContent": ""
                        },
                        {
                            "data": "eFileDraft",
                            "render": function(data) { return data ? formatDate(data) : ''; },
                            "defaultContent": ""
                        },
                        {
                            "data": "eFileFinal",
                            "render": function(data) { return data ? formatDate(data) : ''; },
                            "defaultContent": ""
                        },
                        {
                            "data": "amountofTaxPay",
                            "render": function(data) { return data ? parseFloat(data).toFixed(2) : ''; },
                            "defaultContent": ""
                        },
                        { "data": "taxReferennceNo", "defaultContent": "" },
                        { "data": "login", "defaultContent": "" },
                        { "data": "password", "defaultContent": "" },
                        { "data": "typeofForm", "defaultContent": "" },
                        { "data": "invoicesNo", "defaultContent": "" },
                        {
                            "data": "invoiceAmount",
                            "render": function(data) { return data ? parseFloat(data).toFixed(2) : ''; },
                            "defaultContent": ""
                        },
                        {
                            "data": "id",
                            "render": function(data, type, row) {
                                return `
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-warning edit-btn" data-id="${data}" title="Edit"><i class="fas fa-edit"></i></button>
                                        <button class="btn btn-sm btn-danger delete-btn" data-id="${data}" title="Delete"><i class="fas fa-trash"></i></button>
                                    </div>
                                `;
                            },
                            "orderable": false
                        }
                    ],
                    "order": [[0, 'desc']]
                });
            }

            function saveBP33Record() {
                const formData = {
                    id: currentEditId || 0,
                    item: $('#item').val(),
                    grouping: $('#grouping').val(),
                    companyName: $('#companyName').val(),
                    draftTaxCompleted: $('#draftTaxCompleted').val(),
                    reviewTax: $('#reviewTax').val(),
                    finalTax: $('#finalTax').val(),
                    taxComFinalSignByClient: $('#taxComFinalSignByClient').val(),
                    amountofTaxPay: $('#amountofTaxPay').val(),
                    eFileDraft: $('#eFileDraft').val(),
                    eFileFinal: $('#eFileFinal').val(),
                    taxReferennceNo: $('#taxReferennceNo').val(),
                    login: $('#login').val(),
                    password: $('#password').val(),
                    typeofForm: $('#typeofForm').val(),
                    invoicesNo: $('#invoicesNo').val(),
                    invoiceAmount: $('#invoiceAmount').val()
                };

                const url = currentEditId ? '/api/bp33/update' : '/api/bp33/create';
                const method = currentEditId ? 'PUT' : 'POST';

                $('#saveBtn').prop('disabled', true).html('Saving...');

                $.ajax({
                    url: url,
                    type: method,
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function(response) {
                        $('#saveBtn').prop('disabled', false).html('Save');
                        if (response.success) {
                            $('#taskModal').modal('hide');
                            if(dataTable) dataTable.ajax.reload(null, false);
                            resetForm();
                            showAlert('Saved successfully!', 'success');
                        } else {
                            showAlert('Error: ' + response.message, 'danger');
                        }
                    },
                    error: function(xhr) {
                        $('#saveBtn').prop('disabled', false).html('Save');
                        showAlert('Error saving record', 'danger');
                    }
                });
            }

            function editRecord(id) {
                $.get(`/api/bp33/get/${id}`, function(res) {
                    if (res.success) {
                        const d = res.data;
                        currentEditId = d.id;
                        $('#recordId').val(d.id);

                        // 反选 Dropdown
                        let foundId = "";
                        for (const [key, val] of Object.entries(clientOptionsMap)) {
                            if (val.companyName === d.companyName) {
                                foundId = key;
                                break;
                            }
                        }
                        $('#clientSelect').val(foundId);

                        // 填充 Input
                        $('#item').val(d.item);
                        $('#grouping').val(d.grouping);
                        $('#companyName').val(d.companyName);
                        $('#draftTaxCompleted').val(formatDateForInput(d.draftTaxCompleted));
                        $('#reviewTax').val(formatDateForInput(d.reviewTax));
                        $('#finalTax').val(formatDateForInput(d.finalTax));
                        $('#taxComFinalSignByClient').val(formatDateForInput(d.taxComFinalSignByClient));
                        $('#amountofTaxPay').val(d.amountofTaxPay);
                        $('#eFileDraft').val(formatDateForInput(d.eFileDraft));
                        $('#eFileFinal').val(formatDateForInput(d.eFileFinal));
                        $('#taxReferennceNo').val(d.taxReferennceNo);
                        $('#login').val(d.login);
                        $('#password').val(d.password);
                        $('#typeofForm').val(d.typeofForm);
                        $('#invoicesNo').val(d.invoicesNo);
                        $('#invoiceAmount').val(d.invoiceAmount);

                        $('#modalTitle').text('Edit BP33 Record');
                        $('#taskModal').modal('show');
                    } else {
                        showAlert('Failed to load record', 'danger');
                    }
                });
            }

            function deleteRecord(id) {
                if (confirm('Are you sure?')) {
                    $.ajax({
                        url: `/api/bp33/delete/${id}`,
                        type: 'DELETE',
                        success: function(res) {
                            if (res.success) {
                                dataTable.ajax.reload(null, false);
                                showAlert('Deleted', 'success');
                            } else {
                                showAlert('Delete failed', 'danger');
                            }
                        }
                    });
                }
            }

            // Init
            initializeDatePickers();
            loadClientOptions(); // 🟢 启动加载 Client List
            initializeDataTable();

            // Bindings
            $('#saveBtn').click(saveBP33Record);
            $('#addNewBtn').click(function() { resetForm(); });
            $(document).on('click', '.edit-btn', function() { editRecord($(this).data('id')); });
            $(document).on('click', '.delete-btn', function() { deleteRecord($(this).data('id')); });
            $('#taskModal').on('hidden.bs.modal', resetForm);
        });
    </script>
}