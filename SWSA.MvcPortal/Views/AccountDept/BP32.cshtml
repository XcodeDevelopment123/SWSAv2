@{
    ViewData["Title"] = "BP32 - Tax Compliance Management";
}

<style>
    .dt-button-collection {
        max-height: 350px;
        overflow-y: auto;
        overscroll-behavior: contain;
    }
</style>

<h1>F3.1 Work In Progress</h1>

<div class="row">
    <div class="col-md-12">
        <div id="alertContainer"></div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-file-invoice-dollar me-2"></i> BP32 Records (Sdn Bhd)
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#taskModal" id="addNewBtn">
                        <i class="fas fa-plus me-2"></i>New Record
                    </button>
                </div>
            </div>
            <div class="card-body">
                <table id="taskDatatable" class="table table-bordered table-striped table-responsive">
                    <thead>
                        <tr>
                            <th colspan="3" class="text-center">Basic Information</th>
                            <th colspan="8" class="text-center">Company Details</th>
                            <th colspan="6" class="text-center">Scheduling &amp; Timeline</th>
                            <th colspan="10" class="text-center">Tax Process Steps</th>
                            <th colspan="6" class="text-center">E-Filing &amp; Billing</th>
                            <th rowspan="3" style="vertical-align: middle;">Actions</th>
                        </tr>
                        <tr>
                            <th rowspan="2" style="vertical-align: middle;">File No</th>
                            <th rowspan="2" style="vertical-align: middle;">Company Name</th>
                            <th rowspan="2" style="vertical-align: middle;">Year End</th>

                            <th rowspan="2" style="vertical-align: middle;">Job Type</th>
                            <th rowspan="2" style="vertical-align: middle;">Job Services</th>
                            <th rowspan="2" style="vertical-align: middle;">Co Status</th>
                            <th rowspan="2" style="vertical-align: middle;">Activity Size</th>
                            <th rowspan="2" style="vertical-align: middle;">YE to do</th>
                            <th colspan="1" class="text-center">Month</th>

                            <th colspan="1" style="vertical-align: middle;" class="text-center">Doc Received</th>
                            <th colspan="1" class="text-center">Month <br />to do</th>
                            <th colspan="1" style="vertical-align: middle;" class="text-center">Doc<br />Received<br />Date</th>
                            <th rowspan="2" style="vertical-align: middle;">Tax Due Date</th>
                            <th rowspan="2" style="vertical-align: middle;">Staff</th>

                            <th rowspan="2" style="vertical-align: middle;">Start Date</th>
                            <th rowspan="2" style="vertical-align: middle;">End Date</th>
                            <th rowspan="2" style="vertical-align: middle;">Time Taken</th>
                            <th colspan="1" style="vertical-align: middle;" class="text-center">Date</th>
                            <th rowspan="2" style="vertical-align: middle;">Date Tax Submitted</th>
                            <th rowspan="2" style="vertical-align: middle;">Completed/Backlog</th>
                            <th rowspan="2" style="vertical-align: middle;">Single Entry</th>
                            <th rowspan="2" style="vertical-align: middle;">Tax Computation</th>
                            <th rowspan="2" style="vertical-align: middle;">Sorting Filing</th>
                            <th rowspan="2" style="vertical-align: middle;">Keyin To Excel</th>
                            <th rowspan="2" style="vertical-align: middle;">Review Working Acc</th>
                            <th rowspan="2" style="vertical-align: middle;">Draft Financial Statement</th>
                            <th rowspan="2" style="vertical-align: middle;" class="text-center">Draft<br />Tax Completed</th>
                            <th rowspan="2" style="vertical-align: middle;">Review Tax</th>
                            <th rowspan="2" style="vertical-align: middle;">Final Tax</th>
                            <th rowspan="2" style="vertical-align: middle;">Tax Com Final Sign By Client</th>
                            <th rowspan="2" style="vertical-align: middle;">Amount Tax Pay</th>
                            <th rowspan="2" style="vertical-align: middle;">E-File Draft</th>
                            <th rowspan="2" style="vertical-align: middle;">E-File Final</th>
                            <th rowspan="2" style="vertical-align: middle;">E-File via SPC</th>
                            <th colspan="1" class="text-center">Invoice</th>
                            <th colspan="1" class="text-center">Amount</th>
                        </tr>
                        <tr>
                            <th>to do</th>
                            <th>Date</th>
                            <th>Pass to Audit</th>
                            <th>Date</th>
                            <th>RM</th>
                        </tr>
