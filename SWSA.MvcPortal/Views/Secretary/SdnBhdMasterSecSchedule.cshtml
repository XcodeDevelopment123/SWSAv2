@{
    ViewData["Title"] = "SdnBhdMasterSecSchedule";
}

<style>
    .dt-button-collection {
        max-height: 350px;
        overflow-y: auto;
        overscroll-behavior: contain;
    }
</style>

<h1>D2. Sdn Bhd Master Schedule</h1>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-tasks me-2"></i>
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#taskModal">
                        <i class="fas fa-plus me-2"></i>New Task
                    </button>
                </div>
            </div>
            <div class="card-body" style="overflow:auto">
                <table id="taskDatatable" class="table table-bordered table-striped table-responsive">
                    <thead>
                        <tr>
                            <th colspan="3">Admin</th>
                            <th colspan="2">Co Information</th>
                            <th colspan="11">Scheduling</th>
                            <th colspan="2">Actions</th>
                        </tr>
                        <tr>
                            <th rowspan="2">Grouping</th>
                            <th rowspan="2">Refferal</th>
                            <th rowspan="2">Sec file no</th>
                            <th rowspan="2">Co Name</th>
                            <th rowspan="2">Year End</th>
                            <th colspan="5">Work Allocation</th>
                            <th colspan="3">SSM Due Dates</th>
                            <th colspan="3">SSM Submission</th>
                            <th rowspan="2">Edit</th>
                            <th rowspan="2">Delete</th>
                        </tr>
                        <tr>
                            <th>Co Status</th>
                            <th>Co Activity size</th>
                            <th>Years to Do</th>
                            <th>ACC Mth to do</th>
                            <th>Audit Mth to do</th>
                            <th>1st yr 18 mths due date</th>
                            <th>Circulation & AFS due date</th>
                            <th>Ann Return (AR) Due date</th>
                            <th>AFS Submitted date</th>
                            <th>AR Submitted date</th>
                            <th>Job Completed/Backlog</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="taskModal" tabindex="-1" aria-labelledby="taskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="taskModalLabel">
                    <i class="fas fa-edit me-2"></i>
                    <span id="modalTitle">Add New Sdn Bhd Master Sec Record</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="taskForm">
                    <input type="hidden" id="editIndex" value="">

                    <div class="form-info-label col-12">
                        <label>Admin Information</label>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="grouping">Grouping</label>
                                <input type="text" id="grouping" name="grouping" class="form-control" placeholder="Auto fill from company" readonly />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="referral">Refferal</label>
                                <input type="text" id="referral" name="referral" class="form-control" placeholder="Auto fill from company" readonly />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="secFileNo">Sec file no</label>
                                <input type="text" id="secFileNo" name="secFileNo" class="form-control" placeholder="Auto fill from company" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Which Database</label>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="dbSource">Which Database</label>
                                <select id="dbSource" name="dbSource" class="form-control">
                                    <option value="">-- Select Database --</option>
                                    <option value="sdnbhd">Sdn Bhd</option>
                                    <option value="llp">LLP</option>
                                </select>
                                <small class="text-muted">
                                    Select a database to load company list.
                                </small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="creditRating">Credit Rating</label>
                                <input type="text" id="creditRating" name="creditRating" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Company Information</label>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="companyName">Company Name</label>
                                <select id="companyName" name="companyName" class="form-control">
                                    <option value="">-- Select company --</option>
                                </select>
                                <small class="text-muted">
                                    Grouping, Referral, File No, Credit Rating, Co Status, Activity Size will be filled automatically.
                                </small>
                            </div>
                        </div>
          
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="yearEnd">Year End</label>
                                <input type="text" id="yearEnd" name="yearEnd" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Work Allocation</label>
                    </div>
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="coStatus">Co Status</label>
                                <input type="text" id="coStatus" name="coStatus" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="activitySize">Activity size</label>
                                <input type="text" id="activitySize" name="activitySize" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="yearToDo">Year to Do</label>
                                <select id="yearToDo" name="yearToDo" class="form-control">
                                    <option value="">-- Select Year --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="accMthToDo">ACC Mth to do</label>
                                <input type="text" id="accMthToDo" name="accMthToDo" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="auditMthToDo">Audit Mth to do</label>
                                <input type="text" id="auditMthToDo" name="auditMthToDo" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>SSM Due Dates</label>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="firstYearDueDate">1st yr 18 mths due date</label>
                                <input type="text" id="firstYearDueDate" name="firstYearDueDate" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="circulationDueDate">Circulation & AFS due date</label>
                                <input type="text" id="circulationDueDate" name="circulationDueDate" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="arDueDate">Ann Return (AR) Due date</label>
                                <input type="text" id="arDueDate" name="arDueDate" class="form-control" placeholder="Auto fill" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>SSM Submission</label>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="afsSubmittedDate">AFS Submitted date</label>
                                <input type="text" id="afsSubmittedDate" name="afsSubmittedDate" class="form-control" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="arSubmittedDate">AR Submitted date</label>
                                <input type="text" id="arSubmittedDate" name="arSubmittedDate" class="form-control" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="jobStatus">Job Completed/Backlog</label>
                                <select id="jobStatus" name="jobStatus" class="form-control">
                                    <option value="">Select Status</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Backlog">Backlog</option>
                                    <option value="In Progress">In Progress</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" id="companyNoHidden" name="CompanyNo" />
                    <input type="hidden" id="incorpDateHidden" name="IncorpDate" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" id="saveBtn">
                    <i class="fas fa-save me-2"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_DatatablesScriptsPartial" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>

    <script>
        let dataTable;
        let dataTableInitialized = false;

        function eqIgnoreCase(a, b) {
            if (!a || !b) return false;
            return String(a).trim().toLowerCase() === String(b).trim().toLowerCase();
        }

        function normalizeDdMMyyyy(str) {
            if (!str) return '';
            return formatDateForDisplay(str);
        }

        function loadCompanyOptions(dbType) {
            let url;
            if (dbType === 'llp') {
                url = "/api/get/llp-company-options";
            } else {
                url = "/api/get/company-options";
            }
            $.ajax({
                url: url,
                type: "GET",
                success: function (res) {
                    const $sel = $("#companyName");
                    $sel.empty().append('<option value="">-- Select company --</option>');

                    if (!(res && res.success && res.data)) return;

                    res.data.forEach(function (o) {
                        const name = o.companyName || o.CompanyName || "-";
                        const grouping = o.grouping || o.Grouping || "";
                        const fileNo = o.fileNo || o.FileNo || "";
                        const referral = o.referral || o.Referral || "";
                        const companyNo = o.companyNo || o.CompanyNo || "";
                        const incorpRaw = o.incorporationDate || o.IncorporationDate || "";
                        const yearEndMonth = o.yearEndMonth || o.YearEndMonth || "";
                        const activitySize = o.activitySize || o.ActivitySize || "";
                        const companyStatus = o.companyStatus || o.CompanyStatus || "";
                        const creditRating = o.creditRating || o.CreditRating || "";

                        const incorpDisplay = formatDateForDisplay ? formatDateForDisplay(incorpRaw) : incorpRaw;

                        $sel.append(`
                            <option value="${name}"
                                    data-grouping="${grouping}"
                                    data-fileno="${fileNo}"
                                    data-referral="${referral}"
                                    data-companyno="${companyNo}"
                                    data-incorpdate="${incorpDisplay}"
                                    data-yearendmonth="${yearEndMonth}"
                                    data-activitysize="${activitySize}"
                                    data-companystatus="${companyStatus}"
                                    data-creditrating="${creditRating}">
                                ${name}
                            </option>
                        `);
                    });
                }
            });
        }

        function addMonthsToDdMmYyyy(dateStr, monthsToAdd) {
            if (!dateStr) return '';
            const s = formatDateForDisplay(dateStr);
            const parts = s.split('/');
            if (parts.length !== 3) return '';
            const day = parseInt(parts[0], 10);
            const month = parseInt(parts[1], 10) - 1;
            const year = parseInt(parts[2], 10);
            if (isNaN(day) || isNaN(month) || isNaN(year)) return '';
            const d = new Date(year, month, day);
            d.setMonth(d.getMonth() + monthsToAdd);
            const dd = String(d.getDate()).padStart(2, '0');
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const yyyy = d.getFullYear();
            return `${dd}/${mm}/${yyyy}`;
        }

        function addMonthsToDdMmYyyyReturnMmYyyy(dateStr, monthsToAdd) {
            if (!dateStr) return '';
            const s = formatDateForDisplay(dateStr);
            const parts = s.split('/');
            if (parts.length !== 3) return '';
            const day = parseInt(parts[0], 10);
            const month = parseInt(parts[1], 10) - 1;
            const year = parseInt(parts[2], 10);
            if (isNaN(day) || isNaN(month) || isNaN(year)) return '';
            const d = new Date(year, month, day);
            d.setMonth(d.getMonth() + monthsToAdd);
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const yyyy = d.getFullYear();
            return `${mm}/${yyyy}`;
        }

        function calcAnniversaryDate(incorpDateStr) {
            if (!incorpDateStr) return '';
            const s = formatDateForDisplay(incorpDateStr);
            const parts = s.split('/');
            if (parts.length !== 3) return '';
            const day = parseInt(parts[0], 10);
            const month = parseInt(parts[1], 10) - 1;
            if (isNaN(day) || isNaN(month)) return '';
            const now = new Date();
            let year = now.getFullYear();
            const anniv = new Date(year, month, day);
            if (anniv < now) {
                year++;
            }
            const dd = String(day).padStart(2, '0');
            const mm = String(month + 1).padStart(2, '0');
            return `${dd}/${mm}/${year}`;
        }

        function getYrFromDdMmYyyy(dateStr) {
            if (!dateStr) return '';
            const s = formatDateForDisplay(dateStr);
            const parts = s.split('/');
            if (parts.length !== 3) return '';
            return parts[2];
        }

        function populateYearToDoDropdown(incorpDateStr) {
            const $sel = $('#yearToDo');
            $sel.empty().append('<option value="">-- Select Year --</option>');
            if (!incorpDateStr) return;
            const yr = getYrFromDdMmYyyy(incorpDateStr);
            if (!yr) return;
            const startYr = parseInt(yr, 10);
            if (isNaN(startYr)) return;
            for (let y = startYr; y <= startYr + 10; y++) {
                $sel.append(`<option value="${y}">${y}</option>`);
            }
        }

        function populateYearToDoDropdownFromYear(yearStr) {
            const $sel = $('#yearToDo');
            $sel.empty().append('<option value="">-- Select Year --</option>');
            const startYr = parseInt(yearStr, 10);
            if (isNaN(startYr)) return;
            for (let y = startYr; y <= startYr + 10; y++) {
                $sel.append(`<option value="${y}">${y}</option>`);
            }
        }

        function monthNameToNumber(monthName) {
            const months = {
                'january': '01', 'february': '02', 'march': '03', 'april': '04',
                'may': '05', 'june': '06', 'july': '07', 'august': '08',
                'september': '09', 'october': '10', 'november': '11', 'december': '12'
            };
            return months[monthName.trim().toLowerCase()] || '';
        }

        function autoCalculate(incorpDateStr, yearEndMonthName) {
            const incorp = formatDateForDisplay(incorpDateStr);

            let yearEndDate = '';
            if (yearEndMonthName && incorp) {
                const m = monthNameToNumber(yearEndMonthName);
                if (m) {
                    const yr = getYrFromDdMmYyyy(incorp);
                    yearEndDate = `28/${m}/${yr}`;
                }
            }

            $('#yearEnd').val(yearEndDate);

            const first18 = addMonthsToDdMmYyyy(incorp, 18);
            $('#firstYearDueDate').val(first18);

            const anniv = calcAnniversaryDate(incorp);
            $('#arDueDate').val(anniv);

            if (yearEndDate) {
                const yr = getYrFromDdMmYyyy(yearEndDate);
                if (yr) {
                    populateYearToDoDropdownFromYear(yr);
                    $('#yearToDo').val(yr);
                }

                const accMth = addMonthsToDdMmYyyyReturnMmYyyy(yearEndDate, 3);
                $('#accMthToDo').val(accMth);

                const auditMth = addMonthsToDdMmYyyyReturnMmYyyy(yearEndDate, 5);
                $('#auditMthToDo').val(auditMth);

                const circulation = addMonthsToDdMmYyyy(yearEndDate, 7);
                $('#circulationDueDate').val(circulation);
            }
        }

        function showModalAlert(msg, type) {
            const map = { success: 'alert-success', error: 'alert-danger', warning: 'alert-warning', info: 'alert-info' };
            const $box = $('#modalAlert');
            $box.removeClass('d-none alert-success alert-danger alert-warning alert-info')
                .addClass(map[type] || 'alert-info')
                .html(msg);
            const $body = $('#taskModal .modal-body');
            $body.stop(true).animate({ scrollTop: 0 }, 200, function () {
                $box.attr('tabindex', -1).focus();
            });
        }
        function hideModalAlert() {
            $('#modalAlert').addClass('d-none').empty();
        }
        function clearFieldErrors() {
            $('#taskForm .is-invalid').removeClass('is-invalid');
            $('#taskForm .invalid-feedback').remove();
        }
        function setFieldError(selector, message) {
            const $f = $(selector);
            if (!$f.length) return;
            $f.addClass('is-invalid');
            if ($f.next('.invalid-feedback').length === 0) {
                $f.after('<div class="invalid-feedback"></div>');
            }
            $f.next('.invalid-feedback').text(message);
        }

        function showAlert(message, type) {
            const cls = type === 'success' ? 'alert-success'
                : type === 'error' ? 'alert-danger'
                    : type === 'warning' ? 'alert-warning' : 'alert-info';
            const html = `<div class="alert ${cls} alert-dismissible fade show" role="alert">
                                    ${message}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                  </div>`;
            $('.card-header').after(html);
            setTimeout(() => $('.alert').alert('close'), type === 'error' ? 5000 : 3000);
        }

        function formatDateForDisplay(s) {
            if (!s) return '';
            if (typeof s !== 'string') s = String(s);
            s = s.trim();
            if (!s) return '';
            if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) return s;
            let m = /\/Date\((\d+)\)\//.exec(s);
            if (m) {
                const ticks = parseInt(m[1], 10);
                if (!isNaN(ticks)) {
                    const d = new Date(ticks);
                    return formatDateObjToDdMmYyyy(d);
                }
            }
            m = /^(\d{4})-(\d{2})-(\d{2})/.exec(s);
            if (m) {
                const y = parseInt(m[1], 10);
                const mo = parseInt(m[2], 10) - 1;
                const d = parseInt(m[3], 10);
                const dt = new Date(y, mo, d);
                return formatDateObjToDdMmYyyy(dt);
            }
            const dt2 = new Date(s);
            if (!isNaN(dt2.getTime())) return formatDateObjToDdMmYyyy(dt2);
            return s;
        }

        function formatDateObjToDdMmYyyy(d) {
            const dd = String(d.getDate()).padStart(2, '0');
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const yyyy = d.getFullYear();
            return `${dd}/${mm}/${yyyy}`;
        }

        function getVal(obj, name) {
            if (!obj) return '';
            if (obj[name] !== undefined && obj[name] !== null) return obj[name];
            const camel = name.charAt(0).toLowerCase() + name.slice(1);
            if (obj[camel] !== undefined && obj[camel] !== null) return obj[camel];
            const targetLower = name.toLowerCase();
            for (const key in obj) {
                if (!Object.prototype.hasOwnProperty.call(obj, key)) continue;
                if (key.toLowerCase() === targetLower) return obj[key];
            }
            return '';
        }

        function clearForm() {
            $('#taskForm')[0].reset();
            $('#editIndex').val('');
            $('#modalTitle').text('Add New Sdn Bhd Master Sec Record');
            hideModalAlert();
            clearFieldErrors();
        }

        $(document).ready(function () {

            $('#dbSource').on('change', function () {
                const dbType = $(this).val();
                clearForm();
                if (dbType) {
                    loadCompanyOptions(dbType);
                } else {
                    $('#companyName').empty().append('<option value="">-- Select company --</option>');
                }
            });

            $('#companyName').on('change', function () {
                const $opt = $(this).find('option:selected');
                const grouping = $opt.data('grouping') || '';
                const referral = $opt.data('referral') || '';
                const fileNo = $opt.data('fileno') || '';
                const companyNo = $opt.data('companyno') || '';
                const incorpDate = $opt.data('incorpdate') || '';
                const yearEndMonth = $opt.data('yearendmonth') || '';
                const activitySize = $opt.data('activitysize') || '';
                const companyStatus = $opt.data('companystatus') || '';
                const creditRating = $opt.data('creditrating') || '';

                $('#grouping').val(grouping);
                $('#referral').val(referral);
                $('#secFileNo').val(fileNo);
                $('#creditRating').val(creditRating);
                $('#coStatus').val(companyStatus);
                $('#activitySize').val(activitySize);
                $('#companyNoHidden').val(companyNo);
                $('#incorpDateHidden').val(incorpDate);

                if (incorpDate && yearEndMonth) {
                    autoCalculate(incorpDate, yearEndMonth);
                } else if (incorpDate) {
                    populateYearToDoDropdown(incorpDate);
                    const first18 = addMonthsToDdMmYyyy(incorpDate, 18);
                    $('#firstYearDueDate').val(first18);
                    const anniv = calcAnniversaryDate(incorpDate);
                    $('#arDueDate').val(anniv);
                }
            });

            $('#yearToDo').on('change', function () {
                const yearEndDate = $('#yearEnd').val();
                const yr = $(this).val();
                if (yearEndDate && yr) {
                    const parts = yearEndDate.split('/');
                    if (parts.length === 3) {
                        const newYearEnd = `${parts[0]}/${parts[1]}/${yr}`;
                        $('#yearEnd').val(newYearEnd);
                        const accMth = addMonthsToDdMmYyyyReturnMmYyyy(newYearEnd, 3);
                        $('#accMthToDo').val(accMth);
                        const auditMth = addMonthsToDdMmYyyyReturnMmYyyy(newYearEnd, 5);
                        $('#auditMthToDo').val(auditMth);
                        const circulation = addMonthsToDdMmYyyy(newYearEnd, 7);
                        $('#circulationDueDate').val(circulation);
                    }
                }
            });

            $('input[type="text"]').filter(function () {
                const id = $(this).attr('id') || '';
                return id.includes('Date') || id.includes('date') || id.includes('yearEnd');
            }).datepicker({
                format: 'dd/mm/yyyy',
                autoclose: true,
                todayHighlight: true
            });

            dataTable = $('#taskDatatable').DataTable({
                responsive: true,
                ordering: true,
                autoWidth: false,
                pageLength: 10,
                lengthChange: false,
                order: [[3, 'asc']],
                dom: '<"d-flex justify-content-between align-items-center mb-2"Bf>rtip',
                buttons: ["copy", "csv", "excel", "pdf", "print", "colvis"],
                language: {
                    search: "Search:",
                    lengthMenu: "Show _MENU_ entries",
                    emptyTable: "No records found",
                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                    infoEmpty: "Showing 0 to 0 of 0 entries",
                    paginate: {
                        first: "First",
                        last: "Last",
                        next: "Next",
                        previous: "Previous"
                    }
                },
                columns: [
                    { data: 0 },  // Grouping
                    { data: 1 },  // Referral
                    { data: 2 },  // Sec file no
                    { data: 3 },  // Co Name
                    { data: 4 },  // Year End
                    { data: 5 },  // Co Status
                    { data: 6 },  // Co Activity size
                    { data: 7 },  // Years to Do
                    { data: 8 },  // ACC Mth to do
                    { data: 9 },  // Audit Mth to do
                    { data: 10 }, // 1st yr 18 mths due date
                    { data: 11 }, // Circulation & AFS due date
                    { data: 12 }, // Ann Return (AR) Due date
                    { data: 13 }, // AFS Submitted date
                    { data: 14 }, // AR Submitted date
                    { data: 15 }, // Job Completed/Backlog
                    { data: 16, orderable: false, searchable: false }, // Edit
                    { data: 17, orderable: false, searchable: false }  // Delete
                ]
            });
            dataTableInitialized = true;

            $('#saveBtn').click(saveRecord);
            $(document).on('click', '.edit-btn', function () { editRecord($(this).data('id')); });
            $(document).on('click', '.delete-btn', function () { deleteRecord($(this).data('id')); });

            $('#taskModal').on('hidden.bs.modal', clearForm);

            $('[data-bs-target="#taskModal"]').on('click', function () {
                clearForm();
            });

            loadRecordsFromDatabase();
        });

        function loadRecordsFromDatabase() {
            $.ajax({
                url: 'api/s13a/get-all',
                type: 'GET',
                success: function (res) {
                    if (res && res.success) {
                        populateTable(res.data || []);
                        showAlert('Loaded ' + (res.data?.length || 0) + ' records.', 'success');
                    } else {
                        showAlert('Failed to load: ' + (res?.message || 'Unknown error'), 'error');
                    }
                },
                error: function (xhr) {
                    showAlert('Failed to load: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }

        function populateTable(records) {
            if (!dataTableInitialized) return;
            dataTable.clear();

            if (records && records.length) {
                records.forEach(function (r) {
                    const id = getVal(r, 'Id');
                    dataTable.row.add([
                        getVal(r, 'Grouping'),                            // 0
                        getVal(r, 'Referral'),                            // 1
                        getVal(r, 'SecFileNo'),                           // 2
                        getVal(r, 'CompanyName'),                         // 3
                        formatDateForDisplay(getVal(r, 'YearEnd')),       // 4
                        getVal(r, 'CompanyStatus'),                       // 5
                        getVal(r, 'ActiveCoActivitySize'),                // 6
                        getVal(r, 'YEtoDo'),                              // 7
                        getVal(r, 'ACCmthTodo'),                          // 8
                        getVal(r, 'AuditMthTodo'),                        // 9
                        formatDateForDisplay(getVal(r, 'YrMthDueDate')),  // 10
                        formatDateForDisplay(getVal(r, 'Circulation')),   // 11
                        formatDateForDisplay(getVal(r, 'ARdueDate')),     // 12
                        formatDateForDisplay(getVal(r, 'AFSSubmitDate')), // 13
                        formatDateForDisplay(getVal(r, 'ARSubmitDate')),  // 14
                        getVal(r, 'JobCompleted'),                        // 15
                        `<button class="btn btn-sm btn-warning edit-btn" data-id="${id}" title="Edit">
                            <i class="fas fa-edit"></i>
                         </button>`,
                        `<button class="btn btn-sm btn-danger delete-btn" data-id="${id}" title="Delete">
                            <i class="fas fa-trash"></i>
                         </button>`
                    ]);
                });
            }
            dataTable.draw();
        }

        function saveRecord() {
            hideModalAlert();
            clearFieldErrors();

            const formData = {
                Id: ($('#editIndex').val() || '0').trim(),
                Grouping: ($('#grouping').val() || '').trim(),
                Referral: ($('#referral').val() || '').trim(),
                SecFileNo: ($('#secFileNo').val() || '').trim(),
                CompanyName: ($('#companyName').val() || '').trim(),
                CompanyType: '',
                YearEnd: ($('#yearEnd').val() || '').trim(),
                CompanyNo: ($('#companyNoHidden').val() || '').trim(),
                IncorpDate: ($('#incorpDateHidden').val() || '').trim(),
                CompanyStatus: ($('#coStatus').val() || '').trim(),
                ActiveCoActivitySize: ($('#activitySize').val() || '').trim(),
                YEtoDo: ($('#yearToDo').val() || '').trim(),
                ACCmthTodo: ($('#accMthToDo').val() || '').trim(),
                AuditMthTodo: ($('#auditMthToDo').val() || '').trim(),
                YrMthDueDate: ($('#firstYearDueDate').val() || '').trim(),
                Circulation: ($('#circulationDueDate').val() || '').trim(),
                ARdueDate: ($('#arDueDate').val() || '').trim(),
                AFSSubmitDate: ($('#afsSubmittedDate').val() || '').trim(),
                ARSubmitDate: ($('#arSubmittedDate').val() || '').trim(),
                JobCompleted: ($('#jobStatus').val() || '').trim()
            };

            let hasError = false;
            if (!formData.Grouping) { setFieldError('#grouping', 'Required'); hasError = true; }
            if (!formData.Referral) { setFieldError('#referral', 'Required'); hasError = true; }
            if (!formData.SecFileNo) { setFieldError('#secFileNo', 'Required'); hasError = true; }
            if (!formData.CompanyName) { setFieldError('#companyName', 'Required'); hasError = true; }
            if (!formData.YearEnd) { setFieldError('#yearEnd', 'Required'); hasError = true; }
            if (!formData.YEtoDo) { setFieldError('#yearToDo', 'Required'); hasError = true; }

            if (hasError) {
                showModalAlert('Please fix the highlighted fields.', 'error');
                $('#taskForm .is-invalid').first().focus();
                return;
            }

            const isUpdate = Number(formData.Id) > 0;
            const url = isUpdate ? 'api/s13a/update' : 'api/s13a/create';
            const method = isUpdate ? 'PUT' : 'POST';

            const $btn = $('#saveBtn');
            $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Saving...');

            $.ajax({
                url: url,
                type: method,
                contentType: 'application/json',
                data: JSON.stringify(formData),
                success: function (res) {
                    $btn.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save');
                    if (res && res.success) {
                        $('#taskModal').modal('hide');
                        showAlert('Record saved successfully.', 'success');
                        if (res.s14bAction === 'created') {
                            showAlert('Related S1.4B record has been CREATED.', 'info');
                        } else if (res.s14bAction === 'updated') {
                            showAlert('Related S1.4B record has been UPDATED.', 'info');
                        }
                        loadRecordsFromDatabase();
                    } else {
                        const msg = res?.errors ? res.errors.join(', ') : (res?.message || 'Unknown error');
                        showModalAlert('Error saving record: ' + msg, 'error');
                    }
                },
                error: function (xhr) {
                    $btn.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save');
                    showModalAlert('Error saving record: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }

        function editRecord(id) {
            $('#modalTitle').html('<i class="fas fa-spinner fa-spin me-2"></i>Loading...');
            hideModalAlert();
            clearFieldErrors();

            $.ajax({
                url: 'api/s13a/get/' + id,
                type: 'GET',
                success: function (res) {
                    $('#modalTitle').html('<i class="fas fa-edit me-2"></i>Edit Sdn Bhd Master Sec Record');
                    if (res && res.success) {
                        const d = res.data || {};
                        $('#editIndex').val(getVal(d, 'Id'));
                        $('#grouping').val(getVal(d, 'Grouping'));
                        $('#referral').val(getVal(d, 'Referral'));
                        $('#secFileNo').val(getVal(d, 'SecFileNo'));
                        $('#companyName').empty().append('<option value="' + (getVal(d, 'CompanyName') || '') + '" selected>' + (getVal(d, 'CompanyName') || '') + '</option>');
                        $('#yearEnd').val(formatDateForDisplay(getVal(d, 'YearEnd')));
                        $('#creditRating').val('');
                        $('#coStatus').val(getVal(d, 'CompanyStatus'));
                        $('#activitySize').val(getVal(d, 'ActiveCoActivitySize'));

                        const yeTodo = getVal(d, 'YEtoDo') || '';
                        if (yeTodo) {
                            populateYearToDoDropdownFromYear(yeTodo);
                            $('#yearToDo').val(yeTodo);
                        } else {
                            populateYearToDoDropdown('');
                        }

                        $('#accMthToDo').val(getVal(d, 'ACCmthTodo'));
                        $('#auditMthToDo').val(getVal(d, 'AuditMthTodo'));
                        $('#firstYearDueDate').val(formatDateForDisplay(getVal(d, 'YrMthDueDate')));
                        $('#circulationDueDate').val(formatDateForDisplay(getVal(d, 'Circulation')));
                        $('#arDueDate').val(formatDateForDisplay(getVal(d, 'ARdueDate')));
                        $('#afsSubmittedDate').val(formatDateForDisplay(getVal(d, 'AFSSubmitDate')));
                        $('#arSubmittedDate').val(formatDateForDisplay(getVal(d, 'ARSubmitDate')));
                        $('#jobStatus').val(getVal(d, 'JobCompleted'));

                        $('#taskModal').modal('show');
                    } else {
                        showAlert('Error loading record: ' + (res?.message || 'Unknown error'), 'error');
                    }
                },
                error: function (xhr) {
                    $('#modalTitle').html('<i class="fas fa-edit me-2"></i>Edit Sdn Bhd Master Sec Record');
                    showAlert('Error loading record: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }

        function deleteRecord(id) {
            if (!confirm('Are you sure you want to delete this record? This action cannot be undone.')) return;
            $.ajax({
                url: 'api/s13a/delete/' + id,
                type: 'DELETE',
                success: function (res) {
                    if (res && res.success) {
                        showAlert('Record deleted successfully.', 'success');
                        loadRecordsFromDatabase();
                    } else {
                        showAlert('Error deleting record: ' + (res?.message || 'Unknown error'), 'error');
                    }
                },
                error: function (xhr) {
                    showAlert('Error deleting record: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }
    </script>
}
