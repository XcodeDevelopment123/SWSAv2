@{
    ViewData["Title"] = "SdnBhdAccDocReminderSchedule";
}

<h1>I3.1 Account Dept Reminder</h1>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-tasks me-2"></i>
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#taskModal">
                        <i class="fas fa-plus me-2"></i>New Task
                    </button>
                </div>
            </div>
            <div class="card-body" style="overflow:auto">
                <table id="taskDatatable" class="table table-bordered table-striped table-responsive">
                    <thead>
                        <tr>
                            <th rowspan="3">Grouping</th>
                            <th rowspan="3">Company Name</th>
                            <th colspan="7">Planing & Allocation</th>
                            <th colspan="6">Doc request</th>
                            <th colspan="2">Inward Doc</th>
                            <th colspan="2">Actions</th>
                        </tr>
                        <tr>
                            <th colspan="2">Co Status</th>
                            <th rowspan="2">Year End</th>
                            <th rowspan="2">PIC</th>
                            <th colspan="2">Due Dates</th>
                            <th colspan="1"></th>
                            <th colspan="2">Mth 1 Email</th>
                            <th colspan="2">Mth 2 Reminder PIC</th>
                            <th colspan="2">Mth 3 Final</th>
                            <th rowspan="2">Date Received</th>
                            <th rowspan="2">Note</th>
                            <th rowspan="2">Edit</th>
                            <th rowspan="2">Delete</th>
                        </tr>
                        <tr>
                            <th>Active</th>
                            <th>AEX/OT</th>
                            <th>SSM 18 Mth Due</th>
                            <th>SSM/Tax</th>
                            <th>Target to start Acc wk</th>
                            <th>Targeted Date</th>
                            <th>Date sent</th>
                            <th>Targeted call/text</th>
                            <th>Date Remind</th>
                            <th>Targeted Final Text</th>
                            <th>Date text</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="taskModal" tabindex="-1" aria-labelledby="taskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="taskModalLabel">
                    <i class="fas fa-edit me-2"></i>
                    <span id="modalTitle">Add New Account Document Reminder</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="taskForm">
                    <input type="hidden" id="editIndex" value="">

                    <div class="form-info-label col-12">
                        <label>Basic Information</label>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="grouping">Grouping</label>
                                <input type="text" id="grouping" name="grouping" class="form-control" placeholder="Auto fill from company" readonly />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="companyName">Company Name (Linked from Client List)</label>
                                <select id="companyName" name="companyName" class="form-control">
                                    <option value="">-- Select company --</option>
                                </select>
                                <small class="text-muted">Options are linked from the Sdn Bhd Client List. Grouping & Yearend will be filled automatically.</small>
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Planning & Allocation</label>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="coStatusActive">Active</label>
                                <input type="text" id="coStatusActive" name="coStatusActive" class="form-control" placeholder="Auto fill from company" readonly />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="coStatusAEX">AEX/OT</label>
                                <input type="text" id="coStatusAEX" name="coStatusAEX" class="form-control" placeholder="Auto fill from company" readonly />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="yearEnd">Year End</label>
                                <input type="text" id="yearEnd" name="yearEnd" class="form-control" placeholder="Auto fill from company" readonly />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="pic">PIC</label>
                                <select id="pic" name="pic" class="form-control">
                                    <option value="">-- Select from AT2.1 / AEX4.1 --</option>
                                </select>
                                <small class="text-muted">Pulled from AT2.1 (AuditStaff) / AEX4.1 (Team)</small>
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Due Dates</label>
                    </div>
                    <div class="row">

                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="ssm18MonthDue">SSM 18 Mth Due</label>
                                <select id="ssm18Source" class="form-control mb-1">
                                    <option value="">-- Select Sdn Bhd (Incorp Date) --</option>
                                </select>
                                <small class="text-muted">Pulled from Clients · Sdn Bhd (Incorporation Date = base date)</small>
                                <input type="text" id="ssm18MonthDue" name="ssm18MonthDue" class="form-control mt-1" placeholder="Auto Calculated = Incorporation Date + 18 months" readonly />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="ssmTaxDue">SSM/Tax</label>
                                <small class="text-muted d-block">(auto = Year end + 7 months)</small>
                                <input type="text" id="ssmTaxDue" name="ssmTaxDue" class="form-control" placeholder="Auto calculated" readonly />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="targetedStartAcc">Targeted to start Acc wk</label>
                                <small class="text-muted d-block">(auto = Year end + 3 months)</small>
                                <input type="text" id="targetedStartAcc" name="targetedStartAcc" class="form-control" placeholder="Auto calculated" readonly />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Month 1 Email</label>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="mth1TargetedDate">Targeted Date</label>
                                <small class="text-muted">(auto = Year end + 1 months)</small>
                                <input type="text" id="mth1TargetedDate" name="mth1TargetedDate" class="form-control" placeholder="Auto calculated" readonly />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="mth1DateSent">Date sent</label>
                                <input type="text" id="mth1DateSent" name="mth1DateSent" class="form-control" placeholder="Select date" />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Month 2 Reminder PIC</label>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="mth3TargetedCall">Targeted call/text</label>
                                <small class="text-muted">(auto = Year end + 2 months)</small>
                                <input type="text" id="mth3TargetedCall" name="mth3TargetedCall" class="form-control" placeholder="Auto calculated" readonly />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="mth3DateRemind">Date Remind</label>
                                <input type="text" id="mth3DateRemind" name="mth3DateRemind" class="form-control" placeholder="Select date" />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Month 3 Final</label>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="mth4TargetedFinal">Targeted Final Text</label>
                                <small class="text-muted">(auto = Year end + 3 months)</small>
                                <input type="text" id="mth4TargetedFinal" name="mth4TargetedFinal" class="form-control" placeholder="Auto calculated" readonly />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="mth4DateText">Date text</label>
                                <input type="text" id="mth4DateText" name="mth4DateText" class="form-control" placeholder="Select date" />
                            </div>
                        </div>
                    </div>

                    <div class="form-info-label col-12">
                        <label>Inward Document</label>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="inwardDateReceived">Date Received</label>
                                <select id="inwardDateReceived" name="inwardDateReceived" class="form-control">
                                    <option value="">-- Select from A31A (DateReceived) --</option>
                                </select>
                                <small class="text-muted">Pulled from A31A · DateReceived</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="inwardNote">Note</label>
                                <input type="text" id="inwardNote" name="inwardNote" class="form-control" placeholder="Enter note" />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" id="saveBtn">
                    <i class="fas fa-save me-2"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>

    <script>
        let dataTable;
        let dataTableInitialized = false;

        function yearEndMonthToDateString(monthName) {
            if (!monthName) return '';
            const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
            const idx = months.indexOf(monthName);
            if (idx === -1) return monthName;
            const today = new Date();
            let year = today.getFullYear();
            if (idx < today.getMonth()) year += 1;
            const dt = new Date(year, idx + 1, 0);
            return formatDdMMyyyy(dt);
        }

        function loadCompanyOptions() {
            $.ajax({
                url: "/api/get/company-options",
                type: "GET",
                success: function (res) {
                    const $sel = $("#companyName");
                    $sel.empty().append('<option value="">-- Select company --</option>');
                    if (!(res && res.success && res.data)) return;
                    res.data.forEach(o => {
                        const name = o.companyName || o.name || "-";
                        const grouping = o.group || o.grouping || o.groupName || "";
                        const yeMonth = o.yearEndMonth || "";
                        const active = o.active || o.isActive || "";
                        const aex = o.aex || o.aexStatus || "";
                        $sel.append(`<option value="${name}"
                            data-grouping="${grouping}"
                            data-yearendmonth="${yeMonth}"
                            data-active="${active}"
                            data-aex="${aex}">${name}</option>`);
                    });
                }
            });
        }

        function loadPicSourceList() {
            $.ajax({
                url: "/get-b31-pic-sources",
                type: "GET",
                success: function (res) {
                    const $sel = $("#pic");
                    $sel.empty().append('<option value="">-- Select from AT2.1 / AEX4.1 --</option>');
                    if (!(res && res.success && res.data)) return;
                    res.data.forEach(o => {
                        const company = o.companyName || "-";
                        const ye = formatDateForDisplay(o.yearEnd);
                        const pic = o.pic || "-";
                        $sel.append(`<option value="${pic}">${o.sourceType} - ${company} - YE ${ye} - PIC ${pic}</option>`);
                    });
                }
            });
        }

        function loadInwardSourceList() {
            $.ajax({
                url: "/get-b31-inward-sources",
                type: "GET",
                success: function (res) {
                    const $sel = $("#inwardDateReceived");
                    $sel.empty().append('<option value="">-- Select from A31A (DateReceived) --</option>');
                    if (!(res && res.success && res.data)) return;
                    res.data.forEach(o => {
                        const company = o.companyName || "-";
                        const ye = formatDateForDisplay(o.yearEnd);
                        const dr = formatDateForDisplay(o.dateReceived);
                        $sel.append(`<option value="${dr}">${o.sourceType} - ${company} - YE ${ye} - Date ${dr}</option>`);
                    });
                }
            });
        }

        function loadSsm18SourceList() {
            $.ajax({
                url: "/get-b31-sdnbhd-sources",
                type: "GET",
                success: function (res) {
                    const $sel = $("#ssm18Source");
                    $sel.empty().append('<option value="">-- Select Sdn Bhd (Incorp Date) --</option>');
                    if (!(res && res.success && res.data)) return;
                    res.data.forEach(o => {
                        const company = o.companyName || "-";
                        const raw = o.incorporationDate;
                        let incorpDisplay = "", due18 = "";
                        if (raw) {
                            const dt = new Date(raw);
                            if (!isNaN(dt)) {
                                incorpDisplay = formatDdMMyyyy(dt);
                                due18 = formatDdMMyyyy(addMonthsKeepEnd(dt, 17));
                            }
                        }
                        $sel.append(`<option value="${due18}">${company}${incorpDisplay ? " - Incorp " + incorpDisplay : ""}${due18 ? " - 18mth " + due18 : ""}</option>`);
                    });
                }
            });
        }

        function parseDdMMyyyy(s) {
            if (!s) return null;
            const m = /^(\d{2})\/(\d{2})\/(\d{4})$/.exec(s.trim());
            if (!m) return null;
            const d = +m[1], mo = +m[2] - 1, y = +m[3];
            const dt = new Date(y, mo, d);
            if (dt.getFullYear() !== y || dt.getMonth() !== mo || dt.getDate() !== d) return null;
            return dt;
        }
        function formatDdMMyyyy(dt) {
            const dd = String(dt.getDate()).padStart(2, '0');
            const mm = String(dt.getMonth() + 1).padStart(2, '0');
            const yyyy = dt.getFullYear();
            return `${dd}/${mm}/${yyyy}`;
        }
        function addMonthsKeepEnd(dt, months) {
            const y = dt.getFullYear(), m = dt.getMonth(), d = dt.getDate();
            const daysInTarget = new Date(y, m + months + 1, 0).getDate();
            const day = Math.min(d, daysInTarget);
            return new Date(y, m + months, day);
        }

        function showModalAlert(msg, type) {
            const map = { success: 'alert-success', error: 'alert-danger', warning: 'alert-warning', info: 'alert-info' };
            if ($('#modalAlert').length === 0) $('#taskModal .modal-body').prepend('<div id="modalAlert" class="alert d-none"></div>');
            const $box = $('#modalAlert');
            $box.removeClass('d-none alert-success alert-danger alert-warning alert-info').addClass(map[type] || 'alert-info').html(msg);
            $('#taskModal .modal-body').stop(true).animate({ scrollTop: 0 }, 200, function () { $box.attr('tabindex', -1).focus(); });
        }
        function hideModalAlert() { $('#modalAlert').addClass('d-none').empty(); }
        function clearFieldErrors() {
            $('#taskForm .is-invalid').removeClass('is-invalid');
            $('#taskForm .invalid-feedback').remove();
        }
        function setFieldError(selector, message) {
            const $f = $(selector);
            if (!$f.length) return;
            $f.addClass('is-invalid');
            if ($f.next('.invalid-feedback').length === 0) $f.after('<div class="invalid-feedback"></div>');
            $f.next('.invalid-feedback').text(message);
        }
        function showAlert(message, type) {
            const cls = type === 'success' ? 'alert-success' : type === 'error' ? 'alert-danger' : type === 'warning' ? 'alert-warning' : 'alert-info';
            const html = `<div class="alert ${cls} alert-dismissible fade show" role="alert">
                            ${message}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                          </div>`;
            $('.card-header').after(html);
            setTimeout(() => $('.alert').alert('close'), type === 'error' ? 5000 : 3000);
        }
        function formatDateForDisplay(s) {
            if (!s) return '';
            if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) return s;
            return s;
        }
        function clearForm() {
            $('#taskForm')[0].reset();
            $('#editIndex').val('');
            $('#modalTitle').text('Add New Account Document Reminder');
            hideModalAlert();
            clearFieldErrors();
        }

        $(document).ready(function () {
            loadCompanyOptions();
            loadPicSourceList();
            loadInwardSourceList();
            loadSsm18SourceList();

            $('#companyName').on('change', function () {
                const $opt = $(this).find('option:selected');
                const grp = $opt.data('grouping') || '';
                const yeMonth = $opt.data('yearendmonth') || '';
                const active = $opt.data('active') || '';
                const aex = $opt.data('aex') || '';
                const yeDate = yearEndMonthToDateString(yeMonth);
                $('#grouping').val(grp);
                $('#coStatusActive').val(active);
                $('#coStatusAEX').val(aex);
                $('#yearEnd').val(yeDate).trigger('change');
            });

            $('#yearEnd').on('change', function () {
                const ye = parseDdMMyyyy($(this).val());
                $('#ssmTaxDue').val(ye ? formatDdMMyyyy(addMonthsKeepEnd(ye, 7)) : '');
                $('#targetedStartAcc').val(ye ? formatDdMMyyyy(addMonthsKeepEnd(ye, 4)) : '');
                $('#mth1TargetedDate').val(ye ? formatDdMMyyyy(addMonthsKeepEnd(ye, 1)) : '');
                $('#mth3TargetedCall').val(ye ? formatDdMMyyyy(addMonthsKeepEnd(ye, 3)) : '');
                $('#mth4TargetedFinal').val(ye ? formatDdMMyyyy(addMonthsKeepEnd(ye, 4)) : '');
            });

            $('#ssm18Source').on('change', function () {
                $('#ssm18MonthDue').val(($(this).val() || '').trim());
            });

            $('input[type="text"]').filter(function () {
                const id = $(this).attr('id') || '';
                return (id.includes('Date') || id.includes('date')) && !$(this).prop('readonly');
            }).datepicker({ format: 'dd/mm/yyyy', autoclose: true, todayHighlight: true });

            dataTable = $('#taskDatatable').DataTable({
                responsive: true,
                ordering: true,
                autoWidth: false,
                pageLength: 10,
                order: [[6, 'asc']],
                language: {
                    search: "Search:",
                    lengthMenu: "Show _MENU_ entries",
                    emptyTable: "No records found",
                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                    infoEmpty: "Showing 0 to 0 of 0 entries",
                    paginate: { first: "First", last: "Last", next: "Next", previous: "Previous" }
                },
                columns: [
                    { data: 0 }, { data: 1 }, { data: 2 }, { data: 3 }, { data: 4 }, { data: 5 },
                    { data: 6 }, { data: 7 }, { data: 8 }, { data: 9 }, { data: 10 },
                    { data: 11 }, { data: 12 }, { data: 13 }, { data: 14 },
                    { data: 15 }, { data: 16 },
                    { data: 17, orderable: false, searchable: false },
                    { data: 18, orderable: false, searchable: false }
                ]
            });
            dataTableInitialized = true;

            $('#saveBtn').click(saveRecord);
            $(document).on('click', '.edit-btn', function () { editRecord($(this).data('id')); });
            $(document).on('click', '.delete-btn', function () { deleteRecord($(this).data('id')); });
            $('#taskModal').on('hidden.bs.modal', clearForm);

            loadRecordsFromDatabase();
        });

        function loadRecordsFromDatabase() {
            $.ajax({
                url: '/get-b31-records',
                type: 'GET',
                success: function (res) {
                    if (res && res.success) {
                        populateTable(res.data || []);
                        showAlert('Loaded ' + (res.data?.length || 0) + ' records.', 'success');
                    } else {
                        showAlert('Failed to load: ' + (res?.message || 'Unknown error'), 'error');
                    }
                },
                error: function (xhr) {
                    showAlert('Failed to load: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }

        function populateTable(records) {
            if (!dataTableInitialized) return;
            dataTable.clear();
            if (records && records.length) {
                records.forEach(function (r) {
                    dataTable.row.add([
                        r.grouping || '', r.companyName || '',
                        r.activeStatus || '', r.aeXstatus || '',
                        formatDateForDisplay(r.yearEnd), r.pic || '',
                        formatDateForDisplay(r.ssM18MthDue), formatDateForDisplay(r.ssM_TAX),
                        formatDateForDisplay(r.t_startAccWk),
                        formatDateForDisplay(r.t_Date), formatDateForDisplay(r.dateSent),
                        formatDateForDisplay(r.t_Call), formatDateForDisplay(r.dateRemind),
                        formatDateForDisplay(r.t_FinalText), formatDateForDisplay(r.dateText),
                        formatDateForDisplay(r.dateReceived), r.note || '',
                        `<button class="btn btn-sm btn-warning edit-btn" data-id="${r.id || r.Id}" title="Edit"><i class="fas fa-edit"></i></button>`,
                        `<button class="btn btn-sm btn-danger delete-btn" data-id="${r.id || r.Id}" title="Delete"><i class="fas fa-trash"></i></button>`
                    ]);
                });
            }
            dataTable.draw();
        }

        function saveRecord() {
            hideModalAlert();
            clearFieldErrors();
            const formData = {
                Id: ($('#editIndex').val() || '0').trim(),
                Grouping: ($('#grouping').val() || '').trim(),
                CompanyName: ($('#companyName').val() || '').trim(),
                ActiveStatus: ($('#coStatusActive').val() || '').trim(),
                AEXstatus: ($('#coStatusAEX').val() || '').trim(),
                YearEnd: ($('#yearEnd').val() || '').trim(),
                PIC: ($('#pic').val() || '').trim(),
                SSM18MthDue: ($('#ssm18MonthDue').val() || '').trim(),
                SSM_TAX: ($('#ssmTaxDue').val() || '').trim(),
                T_startAccWk: ($('#targetedStartAcc').val() || '').trim(),
                T_Date: ($('#mth1TargetedDate').val() || '').trim(),
                DateSent: ($('#mth1DateSent').val() || '').trim(),
                T_Call: ($('#mth3TargetedCall').val() || '').trim(),
                DateRemind: ($('#mth3DateRemind').val() || '').trim(),
                T_FinalText: ($('#mth4TargetedFinal').val() || '').trim(),
                DateText: ($('#mth4DateText').val() || '').trim(),
                DateReceived: ($('#inwardDateReceived').val() || '').trim(),
                Note: ($('#inwardNote').val() || '').trim()
            };

            let hasError = false;
            if (!formData.Grouping) { setFieldError('#grouping', 'Required'); hasError = true; }
            if (!formData.CompanyName) { setFieldError('#companyName', 'Required'); hasError = true; }
            if (!formData.YearEnd) { setFieldError('#yearEnd', 'Required'); hasError = true; }
            if (!formData.PIC) { setFieldError('#pic', 'Required'); hasError = true; }
            if (!formData.SSM18MthDue) { setFieldError('#ssm18MonthDue', 'Required'); hasError = true; }

            if (hasError) {
                showModalAlert('Please fix the highlighted fields.', 'error');
                $('#taskForm .is-invalid').first().focus();
                return;
            }

            const isUpdate = Number(formData.Id) > 0;
            const url = isUpdate ? '/update-b31' : '/create-b31';
            const method = isUpdate ? 'PUT' : 'POST';
            const $btn = $('#saveBtn');
            $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Saving...');

            $.ajax({
                url: url, type: method, contentType: 'application/json', data: JSON.stringify(formData),
                success: function (res) {
                    $btn.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save');
                    if (res && res.success) {
                        $('#taskModal').modal('hide');
                        showAlert('Record saved successfully.', 'success');
                        loadRecordsFromDatabase();
                    } else {
                        const msg = res?.errors ? res.errors.join(', ') : (res?.message || 'Unknown error');
                        showModalAlert('Error saving record: ' + msg, 'error');
                    }
                },
                error: function (xhr) {
                    $btn.prop('disabled', false).html('<i class="fas fa-save me-2"></i>Save');
                    showModalAlert('Error saving record: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }

        function editRecord(id) {
            $('#modalTitle').html('<i class="fas fa-spinner fa-spin me-2"></i>Loading...');
            hideModalAlert();
            clearFieldErrors();
            $.ajax({
                url: '/get-b31-record/' + id,
                type: 'GET',
                success: function (res) {
                    $('#modalTitle').html('<i class="fas fa-edit me-2"></i>Edit Account Document Reminder');
                    if (res && res.success) {
                        const d = res.data || {};
                        $('#editIndex').val(d.id || d.Id || 0);
                        $('#grouping').val(d.grouping || d.Grouping || '');
                        $('#companyName').val(d.companyName || d.CompanyName || '').trigger('change');
                        $('#coStatusActive').val(d.activeStatus || '');
                        $('#coStatusAEX').val(d.aeXstatus || '');
                        $('#yearEnd').val(d.yearEnd || d.YearEnd || '').trigger('change');
                        $('#pic').val(d.pic || d.PIC || '');
                        const ssm18 = d.ssM18MthDue || '';
                        $('#ssm18MonthDue').val(ssm18);
                        $('#ssm18Source').val(ssm18);
                        $('#ssmTaxDue').val(d.ssM_TAX || '');
                        $('#targetedStartAcc').val(d.t_startAccWk || d.T_startAccWk || '');
                        $('#mth1TargetedDate').val(d.t_Date || d.T_Date || '');
                        $('#mth1DateSent').val(d.dateSent || d.DateSent || '');
                        $('#mth3TargetedCall').val(d.t_Call || d.T_Call || '');
                        $('#mth3DateRemind').val(d.dateRemind || d.DateRemind || '');
                        $('#mth4TargetedFinal').val(d.t_FinalText || d.T_FinalText || '');
                        $('#mth4DateText').val(d.dateText || d.DateText || '');
                        $('#inwardDateReceived').val(d.dateReceived || d.DateReceived || '');
                        $('#inwardNote').val(d.note || d.Note || '');
                        $('#taskModal').modal('show');
                    } else {
                        showAlert('Error loading record: ' + (res?.message || 'Unknown error'), 'error');
                    }
                },
                error: function (xhr) {
                    $('#modalTitle').html('<i class="fas fa-edit me-2"></i>Edit Account Document Reminder');
                    showAlert('Error loading record: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }

        function deleteRecord(id) {
            if (!confirm('Are you sure you want to delete this record? This action cannot be undone.')) return;
            $.ajax({
                url: '/delete-b31/' + id,
                type: 'DELETE',
                success: function (res) {
                    if (res && res.success) {
                        showAlert('Record deleted successfully.', 'success');
                        loadRecordsFromDatabase();
                    } else {
                        showAlert('Error deleting record: ' + (res?.message || 'Unknown error'), 'error');
                    }
                },
                error: function (xhr) {
                    showAlert('Error deleting record: ' + (xhr.statusText || 'Network error'), 'error');
                }
            });
        }
    </script>
}
