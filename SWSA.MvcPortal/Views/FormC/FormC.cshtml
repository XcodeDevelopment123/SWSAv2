@{
    ViewData["Title"] = "FormC";
}

<h1>G1.  Tax Work logbook</h1>

<div class="row">
    <div class="col-md-12">
        <!-- Alert Container -->
        <div id="alertContainer"></div>

        <!-- /.card -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-tasks me-2"></i>Form C Records
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#taskModal" id="addNewBtn">
                        <i class="fas fa-plus me-2"></i>New Record
                    </button>
                </div>
            </div>
            <!-- /.card-header -->
            <div class="card-body" style="overflow:auto">
                <table id="taskDatatable" class="table table-bordered table-striped table-responsive">
                    <thead>
                        <!-- Row 1: Main headers -->
                        <tr>
                            <th colspan="5">TX Tax Scheduling</th>
                            <th colspan="2">Tax WIP</th>
                            <th colspan="2">Metrics</th>
                            <th colspan="3">Tax work process(Date Done)</th>
                            <th rowspan="2">Tax payable</th>
                            <th rowspan="2">Penalties MITRS Submitted</th>
                            <th colspan="2">Form C</th>
                            <th colspan="2">Date to Client</th>
                            <th rowspan="2">Tax payment date</th>
                            <th rowspan="2">C Submitted Date</th>
                            <th colspan="2">Billing</th>
                            <th colspan="2">MIT+TRS Submitted</th>
                            <th rowspan="2">Job Completed</th>
                            <th rowspan="2">Actions</th>
                        </tr>

                        <!-- Row 2: Sub-headers -->
                        <tr>
                            <th>Tax Due Date</th>
                            <th>Qtr to do</th>
                            <th>Year End</th>
                            <th>Year to do</th>
                            <th>Date mgmtAC</th>
                            <th>a. Start Date</th>
                            <th>b. End Date</th>
                            <th>No of days</th>
                            <th>on-time (Days)</th>
                            <th>P&L Analysis</th>
                            <th>CA & Tax comp</th>
                            <th>Draft Form C</th>
                            <th>Tax comp/CA</th>
                            <th>Review</th>
                            <th>Sent</th>
                            <th>Received form Client</th>
                            <th>Inv Date</th>
                            <th>Fees</th>
                            <th>MIT Submitted</th>
                            <th>TRS Submitted</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Data will be loaded dynamically -->
                    </tbody>
                </table>
            </div>
            <!-- /.card-body -->
        </div>
        <!-- /.card -->
    </div>
</div>

<!-- 模态框部分 -->
<div class="modal fade" id="taskModal" tabindex="-1" aria-labelledby="taskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="taskModalLabel">
                    <i class="fas fa-edit me-2"></i>
                    <span id="modalTitle">Add New tax work record</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="taskForm">
                    <input type="hidden" id="recordId" value="">

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="yearEnd">Year End</label>
                                <input type="text" id="yearEnd" name="yearEnd" class="form-control" placeholder="e.g. 31/12" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="yearToDo">Year to do</label>
                                <input type="text" id="yearToDo" name="yearToDo" class="form-control" placeholder="e.g. 2024" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="dateMgmtAccAvailable">Date mgmtAC</label>
                                <input type="text" id="dateMgmtAccAvailable" name="dateMgmtAccAvailable" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="taxDueDate">Tax Due Date</label>
                                <input type="text" id="taxDueDate" name="taxDueDate" class="form-control" readonly placeholder="Auto YE+8 months" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="estQuarterTodo">Qtr to do</label>
                                <input type="text" id="estQuarterTodo" name="estQuarterTodo" class="form-control" placeholder="Enter quarter" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="startDate">a. Start Date</label>
                                <input type="text" id="startDate" name="startDate" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="endDate">Draft Form C</label>
                                <input type="text" id="endDate" name="endDate" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="noOfDays">No of days</label>
                                <input type="text" id="noOfDays" name="noOfDays" class="form-control" placeholder="Enter days" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="onTimeDays">On-time (Days)</label>
                                <input type="text" id="onTimeDays" name="onTimeDays" class="form-control" readonly placeholder="Auto-calculated" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="pnLAnalysis">P&L Analysis</label>
                                <input type="text" id="pnLAnalysis" name="pnLAnalysis" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="cAnTaxCompu">CA & Tax comp</label>
                                <input type="text" id="cAnTaxCompu" name="cAnTaxCompu" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="taxPayableRM">Refund</label>
                                <input type="text" id="taxPayableRM" name="taxPayableRM" class="form-control" placeholder="Enter amount" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="penaltiesRM">Penalties MITRS Submitted</label>
                                <input type="text" id="penaltiesRM" name="penaltiesRM" class="form-control" placeholder="Enter amount" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="taxCompCA">Tax comp/CA</label>
                                <input type="text" id="taxCompCA" name="taxCompCA" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="formC">Review</label>
                                <input type="text" id="formC" name="formC" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="sent">Sent</label>
                                <input type="text" id="sent" name="sent" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="received">Received form Client</label>
                                <input type="text" id="received" name="received" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="taxPaymentDate">Tax payment date</label>
                                <input type="text" id="taxPaymentDate" name="taxPaymentDate" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="formCsubmitedDate">C Submitted Date</label>
                                <input type="text" id="formCsubmitedDate" name="formCsubmitedDate" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="invDate">Inv Date</label>
                                <input type="text" id="invDate" name="invDate" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="fees">Fees</label>
                                <input type="text" id="fees" name="fees" class="form-control" placeholder="Enter fees" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="mitSubmitted">MIT Submitted</label>
                                <input type="text" id="mitSubmitted" name="mitSubmitted" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="trsSubmitted">TRS Submitted</label>
                                <input type="text" id="trsSubmitted" name="trsSubmitted" class="form-control datepicker" placeholder="Select date" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="jobCompleted">Job Completed</label>
                                <select id="jobCompleted" name="jobCompleted" class="form-control">
                                    <option value="">Select Status</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                    <option value="In Progress">In Progress</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" id="saveBtn">
                    <i class="fas fa-save me-2"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- Include DataTables -->
    <partial name="_DatatablesB5ScriptsPartial" />
    
    

    <!-- Include Datepicker -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>

    <script>
        $(document).ready(function() {
            let dataTable;
            let currentEditId = null;

            // 初始化 DataTable
            initializeDataTable();

            // 初始化日期选择器
            initializeDatePickers();

            // 保存按钮点击事件
            $('#saveBtn').click(function() {
                saveFormCRecord();
            });

            // 初始化 DataTable
            function initializeDataTable() {
                dataTable = $('#taskDatatable').DataTable({
                    "paging": true,
                    "lengthChange": true,
                    "searching": true,
                    "ordering": true,
                    "info": true,
                    "autoWidth": false,
                    "responsive": true,
                    "ajax": {
                        "url": "/api/formc/get-all",
                        "type": "GET",
                        "dataSrc": function(response) {
                            if (response.success) {
                                return response.data;
                            } else {
                                console.error('Error loading data:', response.message);
                                showAlert('Error loading data: ' + response.message, 'danger');
                                return [];
                            }
                        }
                    },
                    "columns": [
                        { "data": "yearEnd" },
                        { "data": "yearToDo" },
                        { "data": "taxDueDate" },
                        { "data": "estQuarterTodo" },
                        { "data": "dateMgmtAccAvailable" },
                        { "data": "startDate" },
                        { "data": "endDate" },
                        { "data": "noOfDays" },
                        {
                            "data": null,
                            "render": function(data, type, row) {
                                if (row.taxDueDate && row.formCsubmitedDate) {
                                    var parts1 = row.taxDueDate.split('-');
                                    var parts2 = row.formCsubmitedDate.split('-');
                                    var d1 = new Date(parts1[0], parts1[1] - 1, parts1[2]);
                                    var d2 = new Date(parts2[0], parts2[1] - 1, parts2[2]);
                                    var diff = Math.round((d2 - d1) / (1000 * 60 * 60 * 24));
                                    return diff;
                                }
                                return '';
                            }
                        },
                        { "data": "pnLAnalysis" },
                        { "data": "cAnTaxCompu" },
                        { "data": "taxPayableRM" },
                        { "data": "penaltiesRM" },
                        { "data": "taxCompCA" },
                        { "data": "formC" },
                        { "data": "sent" },
                        { "data": "received" },
                        { "data": "taxPaymentDate" },
                        { "data": "formCsubmitedDate" },
                        { "data": "invDate" },
                        { "data": "fees" },
                        { "data": "mitSubmitted" },
                        { "data": "trsSubmitted" },
                        {
                            "data": "jobCompleted",
                            "render": function(data, type, row) {
                                return data || 'No';
                            }
                        },
                        {
                            "data": "id",
                            "render": function(data, type, row) {
                                return `
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-warning edit-btn" data-id="${data}" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger delete-btn" data-id="${data}" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                `;
                            },
                            "orderable": false
                        }
                    ]
                });
            }

            // 初始化日期选择器
            function initializeDatePickers() {
                $('.datepicker').datepicker({
                    format: 'yyyy-mm-dd',
                    autoclose: true,
                    todayHighlight: true
                });
            }

            // Auto-calculate Tax Due Date from Year End (dd/MM) + 8 months
            function calcTaxDueDate() {
                var ye = $('#yearEnd').val();
                var ytd = $('#yearToDo').val();
                if (ye && ytd) {
                    var parts = ye.split('/');
                    if (parts.length === 2) {
                        var day = parts[0];
                        var month = parseInt(parts[1], 10);
                        month += 8;
                        var year = parseInt(ytd, 10);
                        if (month > 12) { month -= 12; year += 1; }
                        var due = year + '-' + (month < 10 ? '0' : '') + month + '-' + (day < 10 ? '0' : '') + day;
                        $('#taxDueDate').val(due);
                    } else if (parts.length === 3) {
                        // full date dd/MM/yyyy
                        var day = parts[0];
                        var month = parseInt(parts[1], 10) + 8;
                        var year = parseInt(parts[2], 10);
                        if (month > 12) { month -= 12; year += 1; }
                        var due = year + '-' + (month < 10 ? '0' : '') + month + '-' + (day < 10 ? '0' : '') + day;
                        $('#taxDueDate').val(due);
                    }
                }
                calcOnTimeDays();
            }

            // Auto-calculate On-time Days
            function calcOnTimeDays() {
                var dueDate = $('#taxDueDate').val();
                var subDate = $('#formCsubmitedDate').val();
                if (dueDate && subDate) {
                    var parts1 = dueDate.split('-');
                    var parts2 = subDate.split('-');
                    var d1 = new Date(parts1[0], parts1[1] - 1, parts1[2]);
                    var d2 = new Date(parts2[0], parts2[1] - 1, parts2[2]);
                    var diff = Math.round((d2 - d1) / (1000 * 60 * 60 * 24));
                    $('#onTimeDays').val(diff);
                } else {
                    $('#onTimeDays').val('');
                }
            }
            $(document).on('change', '#yearEnd, #yearToDo', calcTaxDueDate);
            $(document).on('change', '#formCsubmitedDate', calcOnTimeDays);

            // 保存表单记录
            function saveFormCRecord() {
                const formData = {
                    yearEnd: $('#yearEnd').val(),
                    yearToDo: $('#yearToDo').val(),
                    taxDueDate: $('#taxDueDate').val(),
                    estQuarterTodo: $('#estQuarterTodo').val(),
                    dateMgmtAccAvailable: $('#dateMgmtAccAvailable').val(),
                    startDate: $('#startDate').val(),
                    endDate: $('#endDate').val(),
                    noOfDays: $('#noOfDays').val(),
                    pnLAnalysis: $('#pnLAnalysis').val(),
                    cAnTaxCompu: $('#cAnTaxCompu').val(),
                    taxPayableRM: $('#taxPayableRM').val(),
                    penaltiesRM: $('#penaltiesRM').val(),
                    taxCompCA: $('#taxCompCA').val(),
                    formC: $('#formC').val(),
                    sent: $('#sent').val(),
                    received: $('#received').val(),
                    taxPaymentDate: $('#taxPaymentDate').val(),
                    formCsubmitedDate: $('#formCsubmitedDate').val(),
                    invDate: $('#invDate').val(),
                    fees: $('#fees').val(),
                    mitSubmitted: $('#mitSubmitted').val(),
                    trsSubmitted: $('#trsSubmitted').val(),
                    jobCompleted: $('#jobCompleted').val()
                };

                const url = currentEditId ? '/api/formc/update' : '/api/formc/create';
                const method = currentEditId ? 'PUT' : 'POST';

                if (currentEditId) {
                    formData.id = currentEditId;
                }

                $.ajax({
                    url: url,
                    type: method,
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function(response) {
                        if (response.success) {
                            $('#taskModal').modal('hide');
                            dataTable.ajax.reload();
                            resetForm();
                            showAlert('Record saved successfully!', 'success');
                        } else {
                            showAlert('Error saving record: ' + response.message, 'danger');
                        }
                    },
                    error: function(xhr, status, error) {
                        showAlert('Error saving record: ' + error, 'danger');
                    }
                });
            }

            // 编辑记录
            $(document).on('click', '.edit-btn', function() {
                const id = $(this).data('id');
                editRecord(id);
            });

            // 删除记录
            $(document).on('click', '.delete-btn', function() {
                const id = $(this).data('id');
                deleteRecord(id);
            });

            // 编辑记录
            function editRecord(id) {
                $.get(`/api/formc/get/${id}`, function(response) {
                    if (response.success) {
                        const record = response.data;
                        currentEditId = record.id;

                        // 填充表单
                        $('#yearEnd').val(record.yearEnd);
                        $('#yearToDo').val(record.yearToDo);
                        $('#taxDueDate').val(record.taxDueDate);
                        $('#estQuarterTodo').val(record.estQuarterTodo);
                        $('#dateMgmtAccAvailable').val(record.dateMgmtAccAvailable);
                        $('#startDate').val(record.startDate);
                        $('#endDate').val(record.endDate);
                        $('#noOfDays').val(record.noOfDays);
                        $('#pnLAnalysis').val(record.pnLAnalysis);
                        $('#cAnTaxCompu').val(record.cAnTaxCompu);
                        $('#taxPayableRM').val(record.taxPayableRM);
                        $('#penaltiesRM').val(record.penaltiesRM);
                        $('#taxCompCA').val(record.taxCompCA);
                        $('#formC').val(record.formC);
                        $('#sent').val(record.sent);
                        $('#received').val(record.received);
                        $('#taxPaymentDate').val(record.taxPaymentDate);
                        $('#formCsubmitedDate').val(record.formCsubmitedDate);
                        $('#invDate').val(record.invDate);
                        $('#fees').val(record.fees);
                        $('#mitSubmitted').val(record.mitSubmitted);
                        $('#trsSubmitted').val(record.trsSubmitted);
                        $('#jobCompleted').val(record.jobCompleted);

                        $('#modalTitle').text('Edit Form C Record');
                        $('#taskModal').modal('show');
                    } else {
                        showAlert('Error loading record: ' + response.message, 'danger');
                    }
                });
            }

            // 删除记录
            function deleteRecord(id) {
                if (confirm('Are you sure you want to delete this record?')) {
                    $.ajax({
                        url: `/api/formc/delete/${id}`,
                        type: 'DELETE',
                        success: function(response) {
                            if (response.success) {
                                dataTable.ajax.reload();
                                showAlert('Record deleted successfully!', 'success');
                            } else {
                                showAlert('Error deleting record: ' + response.message, 'danger');
                            }
                        },
                        error: function(xhr, status, error) {
                            showAlert('Error deleting record: ' + error, 'danger');
                        }
                    });
                }
            }

            // 重置表单
            function resetForm() {
                $('#taskForm')[0].reset();
                $('#onTimeDays').val('');
                $('#taxDueDate').val('');
                currentEditId = null;
                $('#modalTitle').text('Add New tax work Record');
                $('.datepicker').datepicker('update', '');
            }

            // 显示提示信息
            function showAlert(message, type) {
                const alertClass = `alert alert-${type} alert-dismissible fade show`;
                const alertHtml = `
                    <div class="${alertClass}" role="alert">
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
                $('#alertContainer').html(alertHtml);

                // 自动隐藏
                setTimeout(() => {
                    $('.alert').alert('close');
                }, 5000);
            }

            // 模态框关闭时重置表单
            $('#taskModal').on('hidden.bs.modal', function() {
                resetForm();
            });
        });
    </script>
}